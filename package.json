{
  "name": "decor-cli-monorepo",
  "version": "0.0.0-development",
  "private": true,
  "description": "CLI and MCP server for decorating images and videos with backgrounds, templates, and annotations.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mrgoonie/decor-cli"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w decor-cli-core && npm run build -w decor-cli && npm run build -w decor-cli-mcp",
    "typecheck": "tsc -b packages/core packages/cli packages/mcp",
    "lint": "npm run check:source-labels && npm run typecheck",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "smoke:render": "tsx scripts/smoke-render.ts",
    "smoke:cli": "tsx scripts/smoke-cli.ts",
    "smoke:mcp": "tsx scripts/smoke-mcp.ts",
    "backgrounds:publish": "tsx scripts/publish-default-backgrounds.ts",
    "check:source-labels": "tsx scripts/check-source-artifact-names.ts",
    "release:assets": "tsx scripts/build-github-release-assets.ts",
    "release:dry-run": "semantic-release --dry-run"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/node": "^24.0.4",
    "@vitest/coverage-v8": "^3.2.6",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "semantic-release": "^25.0.5",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
