{
  "name": "decor-cli-mcp",
  "version": "0.1.0",
  "description": "MCP server for decor-cli.",
  "type": "module",
  "bin": {
    "decor-mcp": "dist/bin/decor-mcp.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "!dist/.tsbuildinfo",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json && node -e \"fs.chmodSync('dist/bin/decor-mcp.js',0o755)\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run packages/mcp"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.2",
    "decor-cli-core": "0.1.0",
    "zod": "^3.25.67"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
