{
  "name": "decor-cli-core",
  "version": "0.1.0",
  "description": "Shared rendering core for decor-cli.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/.tsbuildinfo",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run packages/core"
  },
  "dependencies": {
    "sharp": "^0.34.2",
    "zod": "^3.25.67"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
